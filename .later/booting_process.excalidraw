			"seed": 1906913572,
			"version": 491,
			"versionNonce": 1691599259,
			"isDeleted": false,
			"boundElements": [],
			"updated": 1770758122513,
			"link": null,
			"locked": false,
			"text": "is a firmware on a computer\nmotherboard  that start \nsystem, perform hardware \nchecks(POST), and loads\nthe operating system(OS)\n",
			"fontSize": 17.966399843679937,
			"fontFamily": 5,
			"textAlign": "left",
			"verticalAlign": "top",
			"containerId": null,
			"originalText": "is a firmware on a computer\nmotherboard  that start \nsystem, perform hardware \nchecks(POST), and loads\nthe operating system(OS)\n",
			"autoResize": true,
			"lineHeight": 1.25,
			"hasTextLink": false,
			"rawText": ""
		},
		{
			"id": "Pxl6rlmc",
			"type": "text",
			"x": -1044.4551687168423,
			"y": 1893.5205369021228,
			"width": 267.1966552734375,
			"height": 112.28999902299961,
			"angle": 0,
			"strokeColor": "#2f9e44",
			"backgroundColor": "#a5d8ff",
			"fillStyle": "solid",
			"strokeWidth": 2,
			"strokeStyle": "solid",
			"roughness": 0,
			"opacity": 100,
			"groupIds": [],
			"frameId": null,
			"index": "aPV",
			"roundness": null,
			"seed": 1632880693,
			"version": 1250,
			"versionNonce": 38441717,
			"isDeleted": false,
			"boundElements": [],
			"updated": 1770760013565,
			"link": null,
			"locked": false,
			"text": "is the modern replacement for \nthe traditional BIOS.\nMore faster booting, more \nsecure(secure boot), support \nfor larger drivers.",
			"fontSize": 17.966399843679937,
			"fontFamily": 5,
			"textAlign": "left",
			"verticalAlign": "top",
			"containerId": null,
			"originalText": "is the modern replacement for \nthe traditional BIOS.\nMore faster booting, more \nsecure(secure boot), support \nfor larger drivers.",
			"autoResize": true,
			"lineHeight": 1.25,
			"hasTextLink": false,
			"rawText": ""
		},
		{
			"id": "kpvrzJQE",
			"type": "text",
			"x": -891.6109949602569,
			"y": 2174.3561992490822,
			"width": 241.9186248779297,
			"height": 202.1219982413993,
			"angle": 0,
			"strokeColor": "#2f9e44",
			"backgroundColor": "#a5d8ff",
			"fillStyle": "solid",
			"strokeWidth": 2,
			"strokeStyle": "solid",
			"roughness": 0,
			"opacity": 100,
			"groupIds": [],
			"frameId": null,
			"index": "aQ",
			"roundness": null,
			"seed": 1408893499,
			"version": 1769,
			"versionNonce": 274981685,
			"isDeleted": false,
			"boundElements": [],
			"updated": 1770761017838,
			"link": null,
			"locked": false,
			"text": "A critical diagnostic in each\npower on of the system, \nwhere the BIOS send test \nsignals to all the hardware \nand check if everything is \nworking, if not it show a \nERROR message or a pip \nsound to tell you somthing \nnot working.",
			"fontSize": 17.966399843679937,
			"fontFamily": 5,
			"textAlign": "left",
			"verticalAlign": "top",
			"containerId": null,
			"originalText": "A critical diagnostic in each\npower on of the system, \nwhere the BIOS send test \nsignals to all the hardware \nand check if everything is \nworking, if not it show a \nERROR message or a pip \nsound to tell you somthing \nnot working.",
			"autoResize": true,
			"lineHeight": 1.25,
			"hasTextLink": false,
			"rawText": ""
		},
		{
			"id": "69095WZj",
			"type": "text",
			"x": -188.63173177857345,
			"y": 2312.063156735258,
			"width": 227.1968994140625,
			"height": 202.1219982413993,
			"angle": 0,
			"strokeColor": "#2f9e44",
			"backgroundColor": "#a5d8ff",
			"fillStyle": "solid",
			"strokeWidth": 2,
