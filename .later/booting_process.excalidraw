			"type": "text",
			"x": -1023.6702328221436,
			"y": 1577.1271898734547,
			"width": 240.62576293945312,
			"height": 134.74799882759953,
			"angle": 0,
			"strokeColor": "#2f9e44",
			"backgroundColor": "#a5d8ff",
			"fillStyle": "solid",
			"strokeWidth": 2,
