			"boundElements": [],
			"updated": 1770762391013,
			"link": null,
			"locked": false,
			"text": "is a small program ixist in \nfirst little shunk of hard \ndisk do next: \n- locate operating system\nkernel\n- Loads the kernel into \ncomputer's memory\n- Start runing the kernel \ncode",
			"fontSize": 17.966399843679937,
			"fontFamily": 5,
			"textAlign": "left",
			"verticalAlign": "top",
			"containerId": null,
			"originalText": "is a small program ixist in \nfirst little shunk of hard \ndisk do next: \n- locate operating system\nkernel\n- Loads the kernel into \ncomputer's memory\n- Start runing the kernel \ncode",
			"autoResize": true,
			"lineHeight": 1.25,
			"hasTextLink": false,
			"rawText": ""
		},
		{
			"id": "WTZe2FQe",
